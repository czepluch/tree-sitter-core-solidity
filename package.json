{
  "name": "tree-sitter-core-solidity",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for Core Solidity (.solc)",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "parser",
    "tree-sitter",
    "solidity",
    "core-solidity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/czepluch/tree-sitter-core-solidity"
  },
  "license": "MIT",
  "scripts": {
    "build": "tree-sitter generate",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.25.0"
  },
  "tree-sitter": [
    {
      "scope": "source.core-solidity",
      "file-types": [
        "solc"
      ],
      "highlights": "queries/core_solidity/highlights.scm",
      "injections": "queries/core_solidity/injections.scm",
      "folds": "queries/core_solidity/folds.scm",
      "locals": "queries/core_solidity/locals.scm"
    }
  ]
}
